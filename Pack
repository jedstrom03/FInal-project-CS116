public class Pack {

    public static final String DEFAULT_COMPANY = "Default Company";
    public static final String DEFAULT_ZONE    = "A1";
    public static final int    DEFAULT_WEIGHT  = 1;
    public static final int    DEFAULT_VOLUME  = 1;

    private static int nextPackageID = 1;

    private int    packageID;
    private String companyName;
    private String zone;
    private Date   deliveryDate;
    private int    weight;
    private int    volume;

    // Default constructor
    public Pack() {
        packageID = nextPackageID++;
        try {
            setCompanyName(DEFAULT_COMPANY);
            setZone(DEFAULT_ZONE);
            setDeliveryDate(new Date());
            setWeight(DEFAULT_WEIGHT);
            setVolume(DEFAULT_VOLUME);
        } catch (PackException e) {}
    }

    // Non default constructor
    public Pack(String companyName, String zone, Date deliveryDate, int weight, int volume) throws PackException {
        packageID = nextPackageID++;
        setCompanyName(companyName);
        setZone(zone);
        setDeliveryDate(deliveryDate);
        setWeight(weight);
        setVolume(volume);
    }

    // Deep copy constructor
    public Pack(Pack other) throws PackException {
        packageID = nextPackageID++;
        setCompanyName(other.companyName);
        setZone(other.zone);
        setDeliveryDate(other.deliveryDate);
        setWeight(other.weight);
        setVolume(other.volume);
    }

    public void setCompanyName(String companyName) throws PackException {
        if (companyName == null || companyName.isEmpty())
            throw new PackException("Company name cannot be empty.");
        this.companyName = companyName;
    }

    public void setZone(String zone) throws PackException {
        if (zone == null || zone.length() != 2)
            throw new PackException("Invalid zone: " + zone);
        char letter = zone.charAt(0);
        char digit  = zone.charAt(1);
        if (letter < 'A' || letter > 'Z' || digit < '1' || digit > '9')
            throw new PackException("Invalid zone: " + zone + " (must be A1-Z9)");
        this.zone = zone;
    }

    public void setDeliveryDate(Date deliveryDate) throws PackException {
        if (deliveryDate == null)
            throw new PackException("Date cannot be null.");
        try {
            this.deliveryDate = new Date(deliveryDate);
        } catch (DateException e) {
            throw new PackException("Bad date: " + e.getMessage());
        }
    }

    public void setWeight(int weight) throws PackException {
        if (weight <= 0)
            throw new PackException("Weight must be greater than 0.");
        this.weight = weight;
    }

    public void setVolume(int volume) throws PackException {
        if (volume <= 0)
            throw new PackException("Volume must be greater than 0.");
        this.volume = volume;
    }

    public int    getPackageID()   { 
        return packageID;   
    }
    public String getCompanyName() { 
        return companyName; 
    }
    public String getZone()        { 
        return zone;        
    }
    public int    getWeight()      { 
        return weight;      
    }
    public int    getVolume()      { 
        return volume;      
    }

    public Date getDeliveryDate() {
        try {
            return new Date(deliveryDate);
        } catch (DateException e) {
            return deliveryDate;
        }
    }

    public String toString() {
        return "Pkg#" + packageID + " " + companyName + " Zone:" + zone
             + " Date:" + deliveryDate + " W:" + weight + " V:" + volume;
    }
}